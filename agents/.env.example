# Google AI
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model used by ALL agents. Optional — defaults to gemini-2.5-flash.
# DO NOT pin a model Google can retire (gemini-2.0-flash was sunset with a 404,
# which silently took down the entire agent tier). Override only to bump versions.
GEMINI_MODEL=gemini-2.5-flash

# Backend (Node/Express API) URL — REQUIRED in production.
# The agent tier calls this for Maya memory, tracker sync, knowledge base, and
# interview intelligence. If unset it defaults to http://localhost:8787, which
# from inside the deployed agents container points to ITSELF — every persistence
# call then fails silently (swallowed exceptions) and "REJECT has no memory".
# Set this to the deployed Node API origin (e.g. https://www.tryreject.co.uk or
# the Node service's Railway domain). The startup guard refuses to boot in
# production if this still points at localhost.
BACKEND_URL=https://your-node-api-url

# Job APIs (for Career Agent)
JSEARCH_API_KEY=your_jsearch_rapidapi_key_here
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_API_KEY=your_adzuna_api_key_here

# Server
PORT=8080

# Set ENV=production on the deployed agents service to enable the startup
# config guard (fails fast if BACKEND_URL is misconfigured).
ENV=development
