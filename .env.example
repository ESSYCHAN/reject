# Server Configuration
PORT=8787
NODE_ENV=development

# OpenAI Configuration (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# ConvertKit Configuration (Optional)
# If not configured, emails are saved to local SQLite database
# Get your API key from: https://app.convertkit.com/account_settings/advanced_settings
CONVERTKIT_API_KEY=your-convertkit-api-key-here
CONVERTKIT_FORM_ID=your-form-id-here

# Client URL (for CORS in development)
CLIENT_URL=http://localhost:5173
